[Script]
VSCO = type=http-request, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/?(.*?)*$), script-path=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/js/VSCO.js, requires-body=true, timeout=60

[MITM]
hostname = %APPEND% api.revenuecat.com
