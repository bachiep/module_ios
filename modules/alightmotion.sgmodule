[Script]
AlightMotion = type=http-response,script-path=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/js/AlightMotion.js,pattern=^https:\/\/us-central1-alight-creative\.cloudfunctions\.net\/getAccountStatusAndLicenses,max-size=131072,requires-body=true,timeout=10,enable=true

[MITM]
hostname = %APPEND% us-central1-alight-creative.cloudfunctions.net
