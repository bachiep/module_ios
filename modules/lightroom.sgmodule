[Script]
Lightroom = type=http-response,pattern=^https:\/\/photos\.adobe\.io\/v\d\/accounts,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/js/lightroom.js,script-update-interval=-1

[MITM]
hostname = %APPEND% photos.adobe.io
