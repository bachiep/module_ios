[Script]
Truecaller = type=http-response,pattern=^https:\/\/premium-[^.]+\.truecaller\.com\/v\d+\/(subscriptions\/status|products\/apple)(\?.*)?$,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/js/TrueCaller.js

[MITM]
hostname = %APPEND% premium*.truecaller.com
