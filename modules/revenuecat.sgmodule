#!url=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/modules/revenuecat.sgmodule
#!name=RevenueCat VIP (All-in-One)
#!desc=Mở khóa Premium cho hàng trăm ứng dụng sử dụng SDK RevenueCat.
#!icon=https://raw.githubusercontent.com/LovedGM/Quantumult-X-TuBiao/main/zishi-cs/zs98.png

[Script]
RevenueCatVip = type=http-response, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/[^/]+$), script-path=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/js/revenuecat.js, requires-body=true, max-size=-1, timeout=60
deleteHeader = type=http-request, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts|subscribers), script-path=https://raw.githubusercontent.com/bachiep/module_ios/refs/heads/main/js/deleteHeader.js, timeout=60

[MITM]
hostname = %APPEND% api.revenuecat.com, api.rc-backup.com
